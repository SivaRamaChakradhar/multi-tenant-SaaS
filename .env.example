# Copy this file to .env and fill in secure values before running in production
# Example .env for local development

# Database
DB_HOST=database
DB_PORT=5432
DB_NAME=saas_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT secret (must be at least 32 characters for security)
JWT_SECRET=change_me_to_a_secure_random_value_of_min_32_chars
JWT_EXPIRES_IN=24h

# Frontend
VITE_API_URL=http://localhost:5001/api
